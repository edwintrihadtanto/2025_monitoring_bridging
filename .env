#--------------------------------------------------------------------
# Example Environment Configuration file
#
# This file can be used as a starting point for your own
# custom .env files, and contains most of the possible settings
# available in a default install.
#
# By default, all of the settings are commented out. If you want
# to override the setting, you must un-comment it by removing the '#'
# at the beginning of the line.
#--------------------------------------------------------------------

#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------

CI_ENVIRONMENT = development
#CI_ENVIRONMENT = production

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------

app.baseURL = 'http://localhost/2025_monitoring_bridging/'
# If you have trouble with `.`, you could also use `_`.
# app_baseURL = ''
# app.forceGlobalSecureRequests = false
# app.CSPEnabled = false

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------

# database.default.hostname = localhost
# database.default.database = ci4
# database.default.username = root
# database.default.password = root
# database.default.DBDriver = MySQLi
# database.default.DBPrefix =
# database.default.port = 3306

# If you use MySQLi as tests, first update the values of Config\Database::$tests.
# database.tests.hostname = localhost
# database.tests.database = ci4_test
# database.tests.username = root
# database.tests.password = root
# database.tests.DBDriver = MySQLi
# database.tests.DBPrefix =
# database.tests.charset = utf8mb4
# database.tests.DBCollat = utf8mb4_general_ci
# database.tests.port = 3306

#--------------------------------------------------------------------
# ENCRYPTION
#--------------------------------------------------------------------

# encryption.key =

#--------------------------------------------------------------------
# SESSION
#--------------------------------------------------------------------

# session.driver = 'CodeIgniter\Session\Handlers\FileHandler'
# session.savePath = null

session.driver = CodeIgniter\Session\Handlers\DatabaseHandler
session.savePath = ci_sessions

# Opsional: Sesuaikan durasi session (dalam detik, 7200 detik = 2 jam)
session.expiration = 7200

# Opsional: Atur Garbage Collection (Pembersihan session mati)
# 1 berarti 1% kemungkinan membersihkan session lama tiap reload halaman
session.timeToUpdate = 300
session.regenerateDestroy = false

# session.gc_probability: Mengatur probabilitas penghapusan (1/100).
session.gc_probability = 1
session.gc_maxlifetime = 14400

#--------------------------------------------------------------------
# LOGGER
#--------------------------------------------------------------------

Penjelasan Angka Threshold:

#0 = Matikan Log (Tidak mencatat apa-apa).
#1 = Emergency (Bahaya sekali).
#2 = Critical.
#3 = Error (Error skrip PHP).
#4 = Warning (Peringatan).
#5 = Notice.
#6 = Info (Informasi umum).
#7 = Debug (Detail lengkap).
#Saran: Untuk Production, biarkan 4 atau 3. Jika ubah ke 7 atau 9, folder logs akan cepat penuh lagi.

logger.threshold = 4

